{
  "name": "retailcortex",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm_config_verify_deps_before_run='' turbo dev",
    "dev:frontend": "turbo dev --filter=frontend",
    "dev:backend": "turbo dev --filter=backend",
    "dev:app": "turbo dev --filter=app",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "biome lint app/src frontend/src",
    "format": "biome format --write app/src frontend/src",
    "check": "biome check --write app/src frontend/src",
    "clean": "turbo clean",
    "backend:dev": "turbo dev --filter=backend",
    "backend:lint": "cd backend && uv run ruff check src/",
    "backend:format": "cd backend && uv run ruff format src/",
    "backend:test": "cd backend && uv run pytest",
    "backend:migrate": "cd backend && uv run aerich upgrade"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "turbo": "^2"
  }
}
